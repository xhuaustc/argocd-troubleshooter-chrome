{
  "manifest_version": 3,
  "name": "ArgoCD Troubleshooter",
  "version": "0.1.0",
  "description": "AI-powered troubleshooting assistant for ArgoCD deployments",
  "permissions": [
    "sidePanel",
    "tabs",
    "cookies",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "ArgoCD Troubleshooter"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
